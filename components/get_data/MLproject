name: get_data
conda_env: conda.yml
entry_points:
  main:
    parameters:
      sample: {type: path}
      artifact_name: {type: str}
      artifact_type: {type: str}
      artifact_description: {type: str}
    command: >
      python run.py
      --sample {sample}
      --artifact_name {artifact_name}
      --artifact_type {artifact_type}
      --artifact_description {artifact_description}
